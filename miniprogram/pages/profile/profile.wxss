.page {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.profile-card {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  padding: 48rpx 32rpx 32rpx;
  color: #ffffff;
}

.profile-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 32rpx;
}

.profile-avatar {
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 24rpx;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.profile-bio {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

.profile-stats {
  display: flex;
  flex-direction: row;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.stat-label {
  font-size: 22rpx;
  opacity: 0.8;
  display: block;
}

.menu-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 0;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
}

.menu-arrow {
  font-size: 32rpx;
  color: #D1D5DB;
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.section-more {
  font-size: 24rpx;
  color: #6B7280;
}

.activity-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.activity-item:last-child {
  border-bottom: none;
}

.activity-item-title {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.activity-item-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.activity-item-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.empty-hint {
  padding: 20rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
  text-align: center;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
}

.modal-scroll {
  max-height: 60vh;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  display: block;
  text-align: center;
  margin-bottom: 32rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
  display: block;
}

.form-input {
  font-size: 28rpx;
  color: #1F2937;
  padding: 16rpx;
  background-color: #F9FAFB;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
}

.profile-location {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-top: 8rpx;
}

.location-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.location-text {
  font-size: 24rpx;
  opacity: 0.8;
}

.picker-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  padding: 16rpx;
  background-color: #F9FAFB;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
  text-align: center;
}

.picker-disabled {
  color: #9CA3AF;
  background-color: #F3F4F6;
}

.modal-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx 0;
}

/* City picker overlay */
.city-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.city-panel {
  background-color: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  height: 70vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

.city-panel-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx 16rpx;
}

.city-panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

.city-panel-close {
  font-size: 32rpx;
  color: #9CA3AF;
  padding: 8rpx 16rpx;
}

.city-search-bar {
  padding: 0 32rpx 20rpx;
}

.city-search-input {
  background-color: #F3F4F6;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1F2937;
}

.city-scroll-area {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 32rpx;
}

.city-option {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #374151;
  border-bottom: 1rpx solid #F3F4F6;
}

.city-option-active {
  color: #4F46E5;
  font-weight: 500;
}

.city-option-check {
  color: #4F46E5;
  font-size: 28rpx;
}

.city-option-custom {
  color: #4F46E5;
  font-weight: 500;
}

.city-option-empty {
  text-align: center;
  padding: 60rpx 0;
  font-size: 28rpx;
  color: #9CA3AF;
}
