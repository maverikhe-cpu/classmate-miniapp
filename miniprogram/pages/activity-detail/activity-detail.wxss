.page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 160rpx;
}

.cover-section {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  padding: 24rpx 32rpx 32rpx;
  color: #ffffff;
  position: relative;
  overflow: hidden;
}

.cover-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.cover-mask {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.35);
}

.status-bar {
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.status-bar .tag {
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.activity-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
  position: relative;
  z-index: 1;
}

.info-card {
  margin-top: -20rpx;
  border-radius: 20rpx 20rpx 16rpx 16rpx;
  position: relative;
  z-index: 1;
}

.detail-categories {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-bottom: 8rpx;
}

.detail-category {
  font-size: 22rpx;
  color: #4F46E5;
  background-color: #EEF2FF;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.info-card .divider {
  margin: 0;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 14rpx 0;
}

.info-icon {
  font-size: 30rpx;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: baseline;
}

.info-label {
  font-size: 26rpx;
  color: #9CA3AF;
  width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
  display: block;
}

/* Photo album */
.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-header .section-title {
  margin-bottom: 0;
}

.upload-btn {
  padding: 8rpx 24rpx;
  background-color: #4F46E5;
  border-radius: 24rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #ffffff;
}

.photo-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
}

.photo-cell {
  position: relative;
  width: calc((100% - 16rpx) / 3);
  aspect-ratio: 1;
}

.photo-thumb {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  background-color: #F3F4F6;
}

.photo-cover-badge {
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  background-color: rgba(79, 70, 229, 0.9);
  border-radius: 12rpx;
  padding: 2rpx 12rpx;
}

.photo-cover-badge-text {
  font-size: 18rpx;
  color: #ffffff;
}

.photo-upload-tile {
  width: calc((100% - 16rpx) / 3);
  aspect-ratio: 1;
  border-radius: 8rpx;
  border: 2rpx dashed #D1D5DB;
  background-color: #F9FAFB;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.tile-icon {
  font-size: 40rpx;
  color: #9CA3AF;
}

.tile-text {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.photo-empty {
  text-align: center;
  padding: 20rpx 0;
}

.description-text {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.8;
  white-space: pre-wrap;
}

.member-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.member-cell {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.member-avatar-wrap {
  position: relative;
}

.member-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background-color: #E5E7EB;
}

.organizer-corner {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  background-color: #4F46E5;
  border-radius: 16rpx;
  padding: 2rpx 10rpx;
  white-space: nowrap;
}

.organizer-corner-text {
  font-size: 18rpx;
  color: #ffffff;
}

.member-name {
  font-size: 24rpx;
  color: #374151;
  margin-top: 16rpx;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-toggle {
  text-align: center;
  font-size: 24rpx;
  color: #4F46E5;
  padding: 4rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
  text-align: center;
  padding: 20rpx 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  padding: 12rpx 24rpx 0;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bottom-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  padding-bottom: 12rpx;
}

.btn-quick {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: none;
  width: auto;
  margin: 0;
  padding: 8rpx 12rpx;
  line-height: 1.5;
  background-color: #F9FAFB;
  border: none;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #6B7280;
  gap: 4rpx;
}

.btn-quick::after {
  border: none;
}

.quick-icon {
  font-size: 24rpx;
}

.quick-label {
  font-size: 22rpx;
}

.action-buttons {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  min-width: 0;
}

/* 底部栏空间紧张，压缩主按钮字号与横向 padding */
.bottom-bar .btn-primary,
.bottom-bar .btn-secondary,
.bottom-bar .btn-danger,
.bottom-bar .btn-disabled {
  padding-left: 12rpx;
  padding-right: 12rpx;
  font-size: 28rpx;
}

.flex-1 {
  flex: 1;
}

.btn-disabled {
  background-color: #E5E7EB;
  color: #9CA3AF;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

.btn-disabled::after {
  border: none;
}

/* Skeleton loading */
.skeleton-page {
  padding: 0 24rpx;
}

.skeleton-cover {
  height: 200rpx;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  border-radius: 0 0 20rpx 20rpx;
}

.skeleton-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 1;
}

.skeleton-card:first-child + .skeleton-card {
  margin-top: -20rpx;
}

.skeleton-row {
  height: 40rpx;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-title {
  height: 32rpx;
  width: 40%;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.skeleton-line {
  height: 28rpx;
  width: 100%;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.skeleton-line.short {
  width: 60%;
}

.skeleton-avatars {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.member-empty {
  text-align: center;
  padding: 20rpx 0;
}
