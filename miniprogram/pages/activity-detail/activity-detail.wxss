.page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 160rpx;
}

.cover-section {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  padding: 40rpx 32rpx;
  color: #ffffff;
}

.status-bar {
  margin-bottom: 16rpx;
}

.status-bar .tag {
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
}

.activity-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.4;
}

.info-card {
  margin-top: -20rpx;
  border-radius: 20rpx 20rpx 16rpx 16rpx;
  position: relative;
  z-index: 1;
}

.detail-categories {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  padding-bottom: 8rpx;
}

.detail-category {
  font-size: 22rpx;
  color: #4F46E5;
  background-color: #EEF2FF;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 8rpx 0;
}

.info-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
}

.info-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: #1F2937;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 20rpx;
  display: block;
}

.description-text {
  font-size: 28rpx;
  color: #4B5563;
  line-height: 1.8;
  white-space: pre-wrap;
}

.member-list {
  display: flex;
  flex-direction: column;
}

.member-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
}

.member-item:not(:last-child) {
  border-bottom: 1rpx solid #F3F4F6;
}

.member-name {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  margin-left: 16rpx;
}

.organizer-badge {
  background-color: #EEF2FF;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #4F46E5;
}

.empty-text {
  font-size: 26rpx;
  color: #9CA3AF;
  text-align: center;
  padding: 20rpx 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bottom-bar-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}

.action-buttons {
  display: flex;
  flex-direction: row;
  flex: 1;
  gap: 16rpx;
}

.flex-1 {
  flex: 1;
}

.btn-share {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 24rpx;
  background-color: transparent;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #6B7280;
  line-height: 1.2;
  flex-shrink: 0;
}

.btn-share::after {
  border: none;
}

.share-icon {
  font-size: 32rpx;
  margin-bottom: 2rpx;
}

.btn-disabled {
  background-color: #E5E7EB;
  color: #9CA3AF;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

.btn-disabled::after {
  border: none;
}

/* Skeleton loading */
.skeleton-page {
  padding: 0 24rpx;
}

.skeleton-cover {
  height: 200rpx;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  border-radius: 0 0 20rpx 20rpx;
}

.skeleton-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  margin-top: -20rpx;
  position: relative;
  z-index: 1;
}

.skeleton-card:first-child + .skeleton-card {
  margin-top: -20rpx;
}

.skeleton-row {
  height: 40rpx;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.skeleton-title {
  height: 32rpx;
  width: 40%;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
}

.skeleton-line {
  height: 28rpx;
  width: 100%;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.skeleton-line.short {
  width: 60%;
}

.skeleton-avatars {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #F3F4F6 25%, #E5E7EB 50%, #F3F4F6 75%);
  background-size: 200% 100%;
  animation: skeleton-pulse 1.5s ease-in-out infinite;
}

@keyframes skeleton-pulse {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.member-empty {
  text-align: center;
  padding: 20rpx 0;
}
