<view class="page">
  <!-- Skeleton loading -->
  <view wx:if="{{!activity}}" class="skeleton-page">
    <view class="skeleton-cover"></view>
    <view class="skeleton-card">
      <view class="skeleton-row" wx:for="{{[1,2,3,4]}}" wx:key="*this"></view>
    </view>
    <view class="skeleton-card">
      <view class="skeleton-title"></view>
      <view class="skeleton-line"></view>
      <view class="skeleton-line short"></view>
    </view>
    <view class="skeleton-card">
      <view class="skeleton-title"></view>
      <view class="skeleton-avatars">
        <view class="skeleton-avatar" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
      </view>
    </view>
  </view>

  <!-- Actual content -->
  <view wx:if="{{activity}}">
    <!-- Cover -->
    <view class="cover-section">
      <view class="status-bar">
        <view class="tag {{statusTagClass}}">{{statusText}}</view>
      </view>
      <text class="activity-title">{{activity.title}}</text>
    </view>

    <!-- Info card -->
    <view class="info-card card">
      <view class="detail-categories" wx:if="{{activity.categories && activity.categories.length > 0}}">
        <text class="detail-category" wx:for="{{activity.categories}}" wx:key="*this">{{item}}</text>
      </view>
      <view class="divider" wx:if="{{activity.categories && activity.categories.length > 0}}"></view>
      <view class="info-row">
        <text class="info-icon">📅</text>
        <view class="info-content">
          <text class="info-label">时间</text>
          <text class="info-value">{{formattedDate}} {{formattedTimeRange}}</text>
        </view>
      </view>
      <view class="divider" wx:if="{{activity.city}}"></view>
      <view class="info-row" wx:if="{{activity.city}}">
        <text class="info-icon">🌍</text>
        <view class="info-content">
          <text class="info-label">地区</text>
          <text class="info-value">{{activity.country}} · {{activity.city}}</text>
        </view>
      </view>
      <view class="divider" wx:if="{{activity.location}}"></view>
      <view class="info-row" wx:if="{{activity.location}}">
        <text class="info-icon">📍</text>
        <view class="info-content">
          <text class="info-label">地点</text>
          <text class="info-value">{{activity.location}}</text>
        </view>
      </view>
      <view class="divider"></view>
      <view class="info-row">
        <text class="info-icon">👤</text>
        <view class="info-content">
          <text class="info-label">发起人</text>
          <text class="info-value">{{creatorName}}</text>
        </view>
      </view>
      <view class="divider"></view>
      <view class="info-row">
        <text class="info-icon">👥</text>
        <view class="info-content">
          <text class="info-label">人数</text>
          <text class="info-value">
            {{activity.members.length}}{{activity.maxMembers ? '/' + activity.maxMembers : ''}}人参加
          </text>
        </view>
      </view>
      <view class="divider" wx:if="{{activity.signupDeadline}}"></view>
      <view class="info-row" wx:if="{{activity.signupDeadline}}">
        <text class="info-icon">⏰</text>
        <view class="info-content">
          <text class="info-label">报名截止</text>
          <text class="info-value">{{formattedDeadline}}</text>
        </view>
      </view>
    </view>

    <!-- Description -->
    <view class="card" wx:if="{{activity.description}}">
      <text class="section-title">活动详情</text>
      <text class="description-text">{{activity.description}}</text>
    </view>

    <!-- Members -->
    <view class="card">
      <text class="section-title">参与成员 ({{activity.members.length}})</text>
      <view class="member-list" wx:if="{{memberDetails.length > 0}}">
        <view class="member-item" wx:for="{{memberDetails}}" wx:key="_openid">
          <image
            class="avatar member-avatar"
            src="{{item.avatarUrl || '/images/default-avatar.png'}}"
            mode="aspectFill"
          />
          <text class="member-name">{{item.nickName || '同学'}}</text>
          <view class="organizer-badge" wx:if="{{item._openid === activity._openid}}">
            <text class="badge-text">发起人</text>
          </view>
        </view>
      </view>
      <view wx:else class="member-empty">
        <text class="empty-text">暂无成员</text>
      </view>
    </view>

    <!-- Bottom bar -->
    <view class="bottom-bar safe-bottom">
      <view class="bottom-bar-inner">
        <view class="action-buttons">
          <block wx:if="{{isCreator}}">
            <button class="btn-secondary flex-1" bindtap="goEdit">编辑</button>
            <button class="btn-danger flex-1" bindtap="cancelActivity" disabled="{{actionLoading}}">取消活动</button>
          </block>
          <block wx:elif="{{hasJoined}}">
            <button class="btn-secondary flex-1" bindtap="cancelSignup" disabled="{{actionLoading}}" loading="{{actionLoading}}">取消报名</button>
          </block>
          <block wx:elif="{{canSignup}}">
            <button class="btn-primary flex-1" bindtap="signup" disabled="{{actionLoading}}" loading="{{actionLoading}}">立即报名</button>
          </block>
          <block wx:else>
            <button class="btn-disabled flex-1" disabled>{{statusText}}</button>
          </block>
        </view>
        <button class="btn-share" open-type="share">
          <text class="share-icon">↗</text>
          分享
        </button>
      </view>
    </view>
  </view>
</view>
