.page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 140rpx;
}

.photo-area {
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background-color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.photo-preview {
  width: 100%;
  height: 480rpx;
}

.form-section {
  padding: 0 24rpx;
}

.form-group {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  display: block;
}

.required {
  color: #EF4444;
}

.form-textarea {
  font-size: 28rpx;
  color: #1F2937;
  width: 100%;
  min-height: 120rpx;
  line-height: 1.6;
}

.tag-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-btn {
  font-size: 24rpx;
  color: #6B7280;
  background-color: #F3F4F6;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 2rpx solid #E5E7EB;
}

.tag-btn-active {
  color: #ffffff;
  background-color: #4F46E5;
  border-color: #4F46E5;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
}
