.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #4F46E5 0%, #6D28D9 30%, #F5F5F5 30%);
}

.step-container {
  padding: 32rpx;
}

.step-header {
  text-align: center;
  padding: 24rpx 0 40rpx;
}

.step-badge {
  display: inline-block;
  font-size: 22rpx;
  color: #4F46E5;
  background: rgba(255, 255, 255, 0.9);
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.step-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.step-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.back-btn {
  position: absolute;
  left: 32rpx;
  top: 24rpx;
  font-size: 32rpx;
  color: #ffffff;
  padding: 8rpx 16rpx;
}

/* Step 1: 输入姓名验证 */
.btn-verify {
  margin-top: 32rpx;
  width: 100%;
}

.error-msg {
  margin-top: 20rpx;
  padding: 16rpx 24rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 12rpx;
}

.error-text {
  font-size: 26rpx;
  color: #EF4444;
}

.verify-hint {
  text-align: center;
  margin-top: 40rpx;
}

.verify-hint-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.match-info {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #F0FDF4;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.match-icon {
  font-size: 28rpx;
  color: #22C55E;
  margin-right: 12rpx;
}

.match-text {
  font-size: 26rpx;
  color: #16A34A;
  font-weight: 500;
}

/* Step 2: 表单 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar-chooser {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.avatar-chooser::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(79, 70, 229, 0.3);
  margin-bottom: 12rpx;
}

.avatar-hint {
  font-size: 24rpx;
  color: #6B7280;
}

.form-group {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.form-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  font-size: 30rpx;
  color: #1F2937;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.picker-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-top: 12rpx;
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  padding: 16rpx;
  background-color: #F9FAFB;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
  text-align: center;
}

.picker-disabled {
  color: #9CA3AF;
  background-color: #F3F4F6;
}

.btn-next {
  margin-top: 40rpx;
  width: 100%;
}

/* Step 3: 确认 */
.step-final {
  padding-top: 48rpx;
}

.confirm-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 48rpx;
}

.confirm-avatar {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  border: 6rpx solid #EEF2FF;
  margin-bottom: 24rpx;
}

.confirm-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.confirm-bio {
  display: block;
  font-size: 28rpx;
  color: #6B7280;
  margin-bottom: 12rpx;
}

.confirm-location {
  display: block;
  font-size: 26rpx;
  color: #9CA3AF;
}

.btn-complete {
  width: 100%;
  padding: 28rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 16rpx;
}
