.page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 160rpx;
}

.form {
  padding: 24rpx;
}

.form-group {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.form-input {
  font-size: 28rpx;
  color: #1F2937;
  padding: 16rpx;
  background-color: #F9FAFB;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
}

.form-textarea {
  font-size: 28rpx;
  color: #1F2937;
  padding: 16rpx;
  background-color: #F9FAFB;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
  width: 100%;
  min-height: 200rpx;
  box-sizing: border-box;
}

.datetime-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.picker-value {
  flex: 1;
  font-size: 28rpx;
  color: #374151;
  padding: 16rpx;
  background-color: #F9FAFB;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
  text-align: center;
}

.datetime-value {
  font-size: 26rpx;
  color: #1F2937;
  padding: 16rpx;
  background-color: #F9FAFB;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
  text-align: center;
}

.calendar-wrap {
  margin-top: 16rpx;
}

.placeholder {
  color: #9CA3AF;
}

.picker-disabled {
  color: #9CA3AF;
  background-color: #F3F4F6;
}

.clear-deadline {
  margin-top: 12rpx;
  text-align: right;
}

.clear-text {
  font-size: 24rpx;
  color: #6B7280;
}

.limit-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.limit-text {
  font-size: 28rpx;
  color: #6B7280;
  margin-left: 16rpx;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 8rpx;
}

.submit-area {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.submit-btn {
  width: 100%;
}
