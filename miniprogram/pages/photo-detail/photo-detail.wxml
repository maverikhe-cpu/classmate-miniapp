<view class="page" wx:if="{{photo}}">
  <image class="photo-full" src="{{photo.fileID}}" mode="widthFix" bindtap="previewImage" />

  <view class="info-section card">
    <view class="info-row">
      <image class="avatar-small" src="{{photo.uploaderAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
      <text class="uploader-name">{{photo.uploaderName}}</text>
      <text class="photo-date">{{displayDate}}</text>
    </view>
    <text class="caption-text" wx:if="{{photo.caption}}">{{photo.caption}}</text>
    <view class="tag-row" wx:if="{{tagList.length > 0}}">
      <text class="photo-tag" wx:for="{{tagList}}" wx:key="name">{{item.icon}} {{item.name}}</text>
    </view>
  </view>

  <view class="actions-row">
    <button class="action-btn" open-type="share">
      <text class="action-icon">↗</text>
      <text class="action-label">分享</text>
    </button>
    <view class="action-btn" wx:if="{{isUploader}}" bindtap="deletePhoto">
      <text class="action-icon">🗑️</text>
      <text class="action-label">删除</text>
    </view>
  </view>
</view>
