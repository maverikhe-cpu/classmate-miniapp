.page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
}

.photo-full {
  width: 100%;
  display: block;
}

.info-section {
  margin: 16rpx 24rpx;
}

.info-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 12rpx;
}

.uploader-name {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
  flex: 1;
}

.photo-date {
  font-size: 24rpx;
  color: #9CA3AF;
}

.caption-text {
  font-size: 30rpx;
  color: #1F2937;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.tag-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
}

.photo-tag {
  font-size: 20rpx;
  color: #4F46E5;
  background-color: #EEF2FF;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

/* Actions */
.actions-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 20rpx 24rpx;
  background-color: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  gap: 60rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  background: none;
  border: none;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #6B7280;
}

.action-btn::after {
  border: none;
}

.action-icon {
  font-size: 36rpx;
}

.action-label {
  font-size: 22rpx;
  color: #6B7280;
}
