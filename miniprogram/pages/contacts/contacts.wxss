.page {
  min-height: 100vh;
  background-color: #0F172A;
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
  background-color: #1E293B;
}

.search-input-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #334155;
  border-radius: 36rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #E2E8F0;
  height: 48rpx;
}

/* 城市卡片横滑 */
.city-cards {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background-color: #1E293B;
}

.city-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  background: linear-gradient(135deg, #334155 0%, #475569 100%);
  border-radius: 16rpx;
  min-width: 100rpx;
  transition: all 0.3s ease;
}

.city-card-active {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  transform: scale(1.05);
}

.city-card-count {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.city-card-name {
  font-size: 20rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.city-card-active .city-card-name {
  color: #E0E7FF;
}

/* 地图 */
.map-wrap {
  position: relative;
  flex-shrink: 0;
}

.contacts-map {
  width: 100%;
  height: 420rpx;
}

.map-legend {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  background: rgba(15, 23, 42, 0.85);
  backdrop-filter: blur(8px);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.legend-item {
  font-size: 20rpx;
  color: #94A3B8;
}

/* 抽屉 */
.drawer {
  flex: 1;
  background: linear-gradient(180deg, #1E293B 0%, #0F172A 100%);
  border-radius: 32rpx 32rpx 0 0;
  margin-top: -20rpx;
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  min-height: 280rpx;
  transition: flex 0.3s ease;
}

.drawer-expanded {
  flex: 2;
}

.drawer-handle {
  padding: 16rpx 24rpx 8rpx;
  text-align: center;
}

.drawer-bar {
  width: 64rpx;
  height: 6rpx;
  background-color: #475569;
  border-radius: 3rpx;
  margin: 0 auto 12rpx;
}

.drawer-title {
  font-size: 26rpx;
  color: #94A3B8;
}

.drawer-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.sort-toggle {
  padding: 6rpx 20rpx;
  border: 1rpx solid #475569;
  border-radius: 20rpx;
}

.sort-toggle-text {
  font-size: 22rpx;
  color: #94A3B8;
}

.drawer-content {
  flex: 1;
  padding: 0 24rpx;
  max-height: 600rpx;
}

/* 分组 */
.group-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0 12rpx;
  border-bottom: 1rpx solid #334155;
}

.group-country {
  font-size: 28rpx;
  font-weight: 600;
  color: #E2E8F0;
}

.group-count {
  font-size: 22rpx;
  color: #64748B;
}

/* 用户列表 */
.user-list {
  padding: 8rpx 0;
}

.user-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(51, 65, 85, 0.5);
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  border: 2rpx solid #334155;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 28rpx;
  color: #E2E8F0;
  font-weight: 500;
}

.user-name-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.user-student-id {
  font-size: 20rpx;
  color: #64748B;
  background-color: #1E293B;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.user-city {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.user-bio {
  font-size: 22rpx;
  color: #64748B;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #64748B;
}

/* 用户弹窗 */
.user-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-modal {
  width: 560rpx;
  background: linear-gradient(180deg, #1E293B 0%, #0F172A 100%);
  border-radius: 32rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 1rpx solid #334155;
}

.modal-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
  border: 4rpx solid #4F46E5;
}

.modal-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #F1F5F9;
  margin-bottom: 8rpx;
}

.modal-student-id {
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
}

.modal-location {
  font-size: 26rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
}

.modal-bio {
  font-size: 26rpx;
  color: #64748B;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-actions {
  width: 100%;
}

.modal-btn {
  width: 100%;
  font-size: 28rpx;
}

.contact-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #334155;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.contact-label {
  font-size: 22rpx;
  color: #64748B;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.contact-value {
  flex: 1;
  font-size: 26rpx;
  color: #E2E8F0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-copy {
  font-size: 24rpx;
  color: #4F46E5;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.no-contact {
  padding: 20rpx;
  text-align: center;
}

.no-contact-text {
  font-size: 26rpx;
  color: #64748B;
}

.add-contact-btn {
  margin-top: 20rpx;
  width: 100%;
  font-size: 28rpx;
  color: #4F46E5;
  background-color: transparent;
  border: 2rpx solid #4F46E5;
  border-radius: 12rpx;
  padding: 16rpx 0;
}

.add-contact-btn::after {
  border: none;
}
