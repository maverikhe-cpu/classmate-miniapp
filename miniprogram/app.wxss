/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: #F5F5F5;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-text-size-adjust: 100%;
  text-size-adjust: 100%;
}

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 卡片通用样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 主色按钮 */
.btn-primary {
  background-color: #4F46E5;
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 20rpx 40rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

/* 次要按钮 */
.btn-secondary {
  background-color: #ffffff;
  color: #4F46E5;
  border: 2rpx solid #4F46E5;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 20rpx 40rpx;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

/* 危险按钮 */
.btn-danger {
  background-color: #ffffff;
  color: #EF4444;
  border: 2rpx solid #EF4444;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 20rpx 40rpx;
  text-align: center;
}

.btn-danger::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}

.tag-open {
  background-color: #EEF2FF;
  color: #4F46E5;
}

.tag-ongoing {
  background-color: #ECFDF5;
  color: #059669;
}

.tag-full {
  background-color: #FEF3C7;
  color: #D97706;
}

.tag-ended {
  background-color: #F3F4F6;
  color: #9CA3AF;
}

.tag-cancelled {
  background-color: #FEE2E2;
  color: #EF4444;
}

.tag-deadline {
  background-color: #FFF7ED;
  color: #EA580C;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.avatar-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.avatar-large {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
}

/* Flex 布局 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

/* 文字省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #F0F0F0;
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-state .empty-text {
  color: #999999;
  font-size: 28rpx;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
