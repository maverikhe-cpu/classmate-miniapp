.picker {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.picker-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 16rpx;
  display: block;
}

.type-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.type-btn {
  font-size: 24rpx;
  color: #6B7280;
  background-color: #F3F4F6;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.type-active {
  color: #ffffff;
  background-color: #4F46E5;
}

.field-row {
  margin-bottom: 12rpx;
}

.field-value {
  font-size: 28rpx;
  color: #374151;
  padding: 16rpx;
  background-color: #F9FAFB;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
  text-align: center;
}

.date-preview {
  margin-top: 12rpx;
  text-align: center;
}

.preview-text {
  font-size: 28rpx;
  color: #4F46E5;
  font-weight: 500;
}
