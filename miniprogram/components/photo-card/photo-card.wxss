.photo-card {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 24rpx;
  gap: 12rpx;
}

.card-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.card-uploader-name {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
  flex: 1;
}

.card-date {
  font-size: 22rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}

.card-photo {
  width: 100%;
  display: block;
}

.card-body {
  padding: 16rpx 24rpx 20rpx;
}

.card-caption {
  font-size: 28rpx;
  color: #1F2937;
  line-height: 1.5;
  display: block;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.card-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.photo-tag {
  font-size: 20rpx;
  color: #4F46E5;
  background-color: #EEF2FF;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.card-stats {
  display: flex;
  flex-direction: row;
  gap: 24rpx;
}

.stat {
  font-size: 24rpx;
  color: #6B7280;
}
