.activity-card {
  padding: 28rpx;
}

.card-header {
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: row;
}

.card-header-main {
  flex: 1;
  min-width: 0;
}

.card-cover {
  width: 144rpx;
  height: 144rpx;
  border-radius: 12rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
  background-color: #F3F4F6;
}

.card-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
  flex: 1;
  margin-right: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-categories {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.card-category {
  display: flex;
  flex-direction: row;
  align-items: center;
  font-size: 20rpx;
  color: #4F46E5;
  background-color: #EEF2FF;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  gap: 4rpx;
}

.category-icon {
  font-size: 18rpx;
}

.category-name {
  font-size: 20rpx;
}

.card-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 6rpx;
}

.meta-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #6B7280;
}

.meta-dot {
  margin: 0 8rpx;
  color: #D1D5DB;
}

.card-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #F3F4F6;
}

.member-info {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.member-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.member-count-text {
  font-size: 24rpx;
  color: #4F46E5;
  font-weight: 500;
}

.detail-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

.signup-badge {
  font-size: 24rpx;
  color: #ffffff;
  background-color: #4F46E5;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-weight: 500;
}

.card-past {
  opacity: 0.55;
}
